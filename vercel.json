{
    "version": 2,
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
        {
            "source": "/partnership",
            "destination": "/strategic-partners.html",
            "permanent": true
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Robots-Tag",
                    "value": "index, follow"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600, must-revalidate"
                }
            ]
        }
    ]
}